    "name": "GitHub Profile Analyzer",
    "description": "Complete collection for the GitHub Profile Analyzer API.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Profiles",
      "item": [
        {
          "name": "Analyze Profile",
          "request": {
            "method": "POST",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/github/analyze/torvalds",
              "host": ["{{baseUrl}}"],
              "path": ["api", "github", "analyze", "torvalds"]
            }
          }
        },
        {
          "name": "Get All Profiles",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/github/profiles?sort=profile_score&order=desc&limit=10&page=1",
              "host": ["{{baseUrl}}"],
              "path": ["api", "github", "profiles"],
              "query": [
                { "key": "sort", "value": "profile_score" },
                { "key": "order", "value": "desc" },
                { "key": "limit", "value": "10" },
                { "key": "page", "value": "1" }
              ]
            }
          }
        },
        {
          "name": "Get Single Profile",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/github/profile/torvalds",
              "host": ["{{baseUrl}}"],
              "path": ["api", "github", "profile", "torvalds"]
            }
          }
        },
        {
          "name": "Compare Profiles",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/github/compare?users=torvalds,gaearon",
              "host": ["{{baseUrl}}"],
              "path": ["api", "github", "compare"],
              "query": [
                { "key": "users", "value": "torvalds,gaearon" }
              ]
            }
          }
        },
        {
          "name": "Delete Profile",
          "request": {
            "method": "DELETE",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{jwt_token}}",
                "type": "text"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/github/profile/torvalds",
              "host": ["{{baseUrl}}"],
              "path": ["api", "github", "profile", "torvalds"]
            }
          }
        },
        {
          "name": "Get DB Stats",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/github/stats",
              "host": ["{{baseUrl}}"],
              "path": ["api", "github", "stats"]
            }
          }
        }
      ]
    },
    {
      "name": "Auth",
      "item": [
        {
          "name": "Register Admin",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "var jsonData = pm.response.json();",
                  "if(jsonData.data && jsonData.data.token) {",
                  "    pm.environment.set(\"jwt_token\", jsonData.data.token);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n    \"username\": \"admin\",\n    \"password\": \"securepassword123\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/auth/register",
              "host": ["{{baseUrl}}"],
              "path": ["api", "auth", "register"]
            }
          }
        },
        {
