# ============================================
# GitHub Profile Analyzer — Environment Config
# ============================================

# Server
PORT=3000
NODE_ENV=development

# MySQL Database
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=your_password_here
DB_NAME=github_analyzer

# GitHub API
# Generate a token at https://github.com/settings/tokens
# A classic token with zero scopes is sufficient for public data
GITHUB_TOKEN=

# JWT Authentication
JWT_SECRET=change_this_to_a_random_64_char_string
JWT_EXPIRES_IN=24h

# Cache (TTL in seconds)
CACHE_TTL=600

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100

# Logging
LOG_LEVEL=info
